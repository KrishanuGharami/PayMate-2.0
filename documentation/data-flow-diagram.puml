@startuml
!theme vibrant

title Data Flow Diagram (Level 0) for PayMate Web App

actor "User" as User
rectangle "PayMate Web App" as App #Application

boundary "Payment Gateway" as PaymentGateway
boundary "AI Service" as AIService

database "User Data" as UserStore
database "Transaction History" as TransactionStore

' User Authentication Flows
User -> App : Login/Signup Info
App -> UserStore : Store/Verify User Credentials
UserStore -> App : User Profile Data
App -> User : Authenticated Session / Dashboard

' Payment & Transaction Flows
User -> App : Payment Request (Amount, Recipient)
App -> PaymentGateway : Authorize Payment
PaymentGateway -> App : Payment Status (Success/Failure)
App -> TransactionStore : Record Transaction Details
App -> User : Display Transaction Confirmation

' AI-driven Flows
User -> App : Support Chat Query
App -> AIService : AI Prompt (User Query)
AIService -> App : AI Generated Response
App -> User : Display Chatbot Response

' AI Suggestions Flow (background process)
TransactionStore -> App : Reads Transaction History
App -> AIService : AI Prompt (Transaction Data)
AIService -> App : Smart Suggestions
App -> User : Display Smart Suggestions

@enduml
