@startuml PayMate Use Case Diagram

!theme vibrant

left to right direction

actor "User" as User
actor "Payment Gateway" as PaymentGateway
actor "AI Service" as AIService

rectangle "PayMate Web App" {
  usecase "Sign Up" as SignUp
  usecase "Log In" as LogIn
  usecase "View Dashboard" as ViewDashboard
  usecase "Get Smart Suggestions" as GetSuggestions
  usecase "Transfer Money" as TransferMoney
  usecase "Transfer via UPI ID" as TransferUPI
  usecase "Transfer via Bank Account" as TransferBank
  usecase "Pay with QR Code" as PayQR
  usecase "Pay Bills" as PayBills
  usecase "View Transaction History" as ViewHistory
  usecase "Get AI Support" as GetSupport
  usecase "Process Payment" as ProcessPayment
}

' Actor to Use Case relationships
User -- SignUp
User -- LogIn
User -- ViewDashboard
User -- TransferMoney
User -- PayBills
User -- ViewHistory
User -- GetSupport

' Include relationships (Login is required for most actions)
ViewDashboard .> (Log In) : <<includes>>
TransferMoney .> (Log In) : <<includes>>
PayBills .> (Log In) : <<includes>>
ViewHistory .> (LogIn) : <<includes>>
GetSupport .> (Log In) : <<includes>>

' Extend relationships for Transfer Money
TransferMoney <|-- TransferUPI
TransferMoney <|-- TransferBank
TransferMoney <|-- PayQR

' Include relationships for core functionalities
ViewDashboard ..> GetSuggestions : <<includes>>
TransferMoney ..> ProcessPayment : <<includes>>
PayBills ..> ProcessPayment : <<includes>>

' System to external actor relationships
GetSuggestions -- AIService
GetSupport -- AIService
ProcessPayment -- PaymentGateway

@enduml
