@startuml
title "PayMate Web App - DFD Level 1 (Compact)"

!theme plain
skinparam rectangle {
    BorderColor #4682B4
    BackgroundColor #ADD8E6
}
skinparam database {
    BorderColor #888
    BackgroundColor #F5F5F5
}
skinparam actor {
    BorderColor #333
}
skinparam arrow {
    FontSize 10
}

actor User

package "PayMate Web App" {
  rectangle "1. Manage \nAccount" as P1
  rectangle "2. Process \nPayments" as P2
  rectangle "3. AI \nAssistance" as P3
  rectangle "4. View \nHistory" as P4
}

database "User Data" as UserStore
database "Transaction Data" as TransactionStore

rectangle "Payment Gateways" as Gateways
rectangle "AI Service" as AIService

' Arrange elements for compactness
User -left-> P1
User -left-> P2
User -left-> P3
User -left-> P4

P1 -up-> UserStore
P2 -down-> TransactionStore
P2 -right-> Gateways
P3 -right-> AIService
P3 -up-> TransactionStore
P4 -up-> TransactionStore

' Data Flows
User -> P1 : Credentials
P1 -> UserStore : Auth Request
UserStore -> P1 : User Profile

User -> P2 : Payment Data
P2 -> Gateways : Payment Request
Gateways -> P2 : Confirmation
P2 -> TransactionStore : Record Txn

User -> P3 : Query / Usage Data
P3 -> AIService : AI Request
AIService -> P3 : AI Response
TransactionStore -> P3 : Txn History
P3 -> User : Suggestions / Help

User -> P4 : Request
TransactionStore -> P4 : History
P4 -> User : Formatted History

@enduml
