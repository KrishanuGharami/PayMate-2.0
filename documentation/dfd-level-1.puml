@startuml
title PayMate Web App: DFD Level 1

!define ENTITY skinparam rectangle<<ENTITY>> { \
    BackgroundColor #F0E68C \
    BorderColor #B8860B \
}
!define PROCESS skinparam ellipse<<PROCESS>> { \
    BackgroundColor #ADD8E6 \
    BorderColor #4682B4 \
}
!define DATASTORE skinparam database<<DATASTORE>> { \
    BackgroundColor #E6E6FA \
    BorderColor #6A5ACD \
}

skinparam default {
    FontName Inter
    FontSize 12
}
skinparam rectangle {
    FontName Inter
    FontSize 14
}
skinparam ellipse {
    FontName Inter
    FontSize 14
}
skinparam database {
    FontName Inter
    FontSize 14
}

' Entities
rectangle "User" as User <<ENTITY>>
rectangle "Payment Gateway\n(Stripe, PayPal, etc.)" as PaymentGateway <<ENTITY>>
rectangle "AI Service\n(Google AI)" as AIService <<ENTITY>>

' Data Stores
database "User Data Store" as UserStore <<DATASTORE>>
database "Transaction Data Store" as TransactionStore <<DATASTORE>>

' Main Process Boundary
rectangle "PayMate Web App" {
    ellipse "1.0\nManage User Account" as P1 <<PROCESS>>
    ellipse "2.0\nProcess Payments" as P2 <<PROCESS>>
    ellipse "3.0\nGenerate AI Assistance" as P3 <<PROCESS>>
    ellipse "4.0\nView History" as P4 <<PROCESS>>
}

' Data Flows

' User Interactions
User --> P1 : Login/Signup Credentials
P1 --> User : Session Token / Welcome

User --> P2 : Payment Details (UPI, Bank, Bill)
P2 --> User : Payment Confirmation / Status

User --> P3 : Support Query / Request for Suggestions
P3 --> User : AI Response / Smart Suggestions

User --> P4 : Request for Transaction History
P4 --> User : Formatted Transaction List

' Process to Data Store Flows
P1 <--> UserStore : User Details
P2 --> TransactionStore : New Transaction Record
P3 <- TransactionStore : Transaction History for AI Analysis
P4 -> TransactionStore : Fetch Transaction Records

' Process to External Entity Flows
P2 --> PaymentGateway : Payment API Request
PaymentGateway --> P2 : Payment API Response (Success/Failure)

P3 --> AIService : AI Prompt (Query, History)
AIService --> P3 : AI Model Output

@enduml
