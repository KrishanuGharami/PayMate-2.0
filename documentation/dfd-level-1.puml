@startuml
title "PayMate - DFD Level 1"

skinparam defaultFontName Inter
skinparam rectangle {
  BackgroundColor #ADD8E6
  BorderColor #4682B4
}
skinparam database {
  BackgroundColor #F5F5DC
  BorderColor #BDB76B
}
skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #000000
}


' External Entities
actor "User" as user
boundary "Payment Gateways" as payment_gateway
boundary "AI Service" as ai_service

' Data Stores
database "User Data" as user_store
database "Transaction Data" as transaction_store

' Processes within the PayMate System
rectangle "1.0\nManage User Account" as p1
rectangle "2.0\nProcess Payments" as p2
rectangle "3.0\nGenerate AI Assistance" as p3
rectangle "4.0\nView History" as p4

' Data Flows

' User interactions
user -->(p1) : Login/Signup Info
user -->(p2) : Transaction Details
user -->(p3) : Support Query
user -->(p4) : View History Request

(p1)-->user : Auth Status
(p2)-->user : Payment Status
(p3)-->user : AI Response
(p4)-->user : Transaction History

' Flows to/from Data Stores
p1 <--> user_store
p2 --> transaction_store : Record Transaction
p3 -> transaction_store : Get Context for Suggestions
p4 -> transaction_store : Fetch History

' Flows to/from External Entities
p2 -> payment_gateway : Payment Request
payment_gateway -> p2 : Payment Response

p3 -> ai_service : AI Prompt
ai_service -> p3 : AI-Generated Content

@enduml
